# Server
NODE_ENV=production
PORT=3001
API_URL=https://api.YOUR_DOMAIN.TLD

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cave_vigne
DB_USER=cave_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT
JWT_SECRET=CHANGE_ME_VERY_LONG_SECRET_KEY_64CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Redis (caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Anthropic API (Sommelier IA)
ANTHROPIC_API_KEY=sk-ant-XXXXX

# Upload
UPLOAD_DIR=/var/www/cave-vigne/uploads
MAX_FILE_SIZE=10485760

# CORS
ALLOWED_ORIGINS=https://api.YOUR_DOMAIN.TLD,https://www.api.YOUR_DOMAIN.TLD

# Cloudflare (optionnel, pour purge cache)
CF_ZONE_ID=your_zone_id
CF_API_TOKEN=your_cf_token
